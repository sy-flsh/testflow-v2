generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MemberRole {
  ADMIN
  MEMBER
  VIEWER
}

enum MemberStatus {
  ACTIVE
  PENDING
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum TestCaseStatus {
  READY
  DRAFT
  DEPRECATED
}

enum RunStatus {
  PLANNED
  IN_PROGRESS
  PAUSED
  COMPLETED
}

enum ResultStatus {
  PENDING
  PASSED
  FAILED
  BLOCKED
  SKIPPED
}

model User {
  id        String            @id @default(cuid())
  email     String            @unique
  name      String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  members   WorkspaceMember[]

  @@map("users")
}

model Workspace {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  description String            @default("")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  members     WorkspaceMember[]
  projects    Project[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String       @id @default(cuid())
  workspaceId String
  userId      String
  role        MemberRole   @default(MEMBER)
  status      MemberStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId, status])
  @@map("workspace_members")
}

model Project {
  id          String        @id @default(cuid())
  workspaceId String
  name        String
  slug        String
  description String        @default("")
  color       String        @default("#2563EB")
  status      ProjectStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  testFolders TestFolder[]
  testCases   TestCase[]
  testRuns    TestRun[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, status])
  @@index([updatedAt])
  @@map("projects")
}

model TestFolder {
  id        String       @id @default(cuid())
  projectId String
  parentId  String?
  slug      String
  name      String
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent    TestFolder?  @relation("TestFolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  TestFolder[] @relation("TestFolderTree")
  testCases TestCase[]

  @@unique([projectId, slug])
  @@index([projectId, parentId])
  @@index([projectId, deletedAt])
  @@map("test_folders")
}

model TestCase {
  id             String          @id @default(cuid())
  projectId      String
  folderId       String
  code           String
  title          String
  priority       Priority        @default(MEDIUM)
  status         TestCaseStatus  @default(DRAFT)
  tags           String[]        @default([])
  authorName     String          @default("김QA")
  description    String          @default("")
  preconditions  String          @default("")
  expectedResult String          @default("")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder         TestFolder      @relation(fields: [folderId], references: [id], onDelete: Restrict)
  steps          TestStep[]
  runResults     TestRunResult[]

  @@unique([projectId, code])
  @@index([projectId, status])
  @@index([projectId, folderId])
  @@index([projectId, deletedAt])
  @@map("test_cases")
}

model TestStep {
  id             String   @id @default(cuid())
  testCaseId     String
  order          Int
  action         String
  expectedResult String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  testCase       TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  @@unique([testCaseId, order])
  @@index([testCaseId])
  @@map("test_steps")
}

model TestRun {
  id           String          @id @default(cuid())
  projectId    String
  slug         String
  title        String
  description  String          @default("")
  assigneeName String          @default("김QA")
  environment  String          @default("QA Server")
  startDate    DateTime
  dueDate      DateTime
  status       RunStatus       @default(PLANNED)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?
  project      Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  results      TestRunResult[]

  @@unique([projectId, slug])
  @@index([projectId, status])
  @@index([projectId, deletedAt])
  @@map("test_runs")
}

model TestRunResult {
  id           String       @id @default(cuid())
  runId        String
  testCaseId   String
  code         String
  status       ResultStatus @default(PENDING)
  actualResult String       @default("")
  defectCount  Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  run          TestRun      @relation(fields: [runId], references: [id], onDelete: Cascade)
  testCase     TestCase     @relation(fields: [testCaseId], references: [id], onDelete: Restrict)

  @@unique([runId, testCaseId])
  @@unique([runId, code])
  @@index([testCaseId])
  @@index([runId, status])
  @@map("test_run_results")
}
